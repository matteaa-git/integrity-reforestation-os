# Instagram / Facebook App credentials
# Create your app at https://developers.facebook.com/
# Required permissions: instagram_basic, instagram_manage_insights, pages_show_list, pages_read_engagement
INSTAGRAM_APP_ID=your_facebook_app_id
INSTAGRAM_APP_SECRET=your_facebook_app_secret

# Must match "Valid OAuth Redirect URIs" configured in your Facebook App settings
INSTAGRAM_REDIRECT_URI=http://localhost:4000/instagram/callback

# ── X (Twitter) App credentials ───────────────────────────────────────────────
# Create your app at https://developer.twitter.com/
# Enable OAuth 2.0 with type "Web App" (confidential client)
# Required scopes: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret

# Must match "Callback URI / Redirect URL" in your X App settings
X_REDIRECT_URI=http://localhost:4000/x/account/callback

# Where the API redirects after successful OAuth
FRONTEND_URL=http://localhost:3001
